# MouseHash analysis paths. Only MOUSEHASH_DATA_ROOT is required;
# the subroots default to <DATA_ROOT>/<subdir> if unset.

MOUSEHASH_DATA_ROOT=/absolute/path/to/mousehash_data
# MOUSEHASH_STIMULI_ROOT=
# MOUSEHASH_CACHE_ROOT=
# MOUSEHASH_REPORTS_ROOT=
# MOUSEHASH_ARTIFACT_ROOT=
# MOUSEHASH_MANIFESTS_ROOT=

# Allen Brain Observatory manifest JSON (only needed when running the Allen vertical).
# ALLEN_MANIFEST_PATH=/absolute/path/to/boc/manifest.json
